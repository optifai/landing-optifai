# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values you need.
# `.env.local` is git-ignored — never commit real keys.
#
# A Vercel preview demo works without any of these: Vercel supplies its own
# project URL, and the contact form falls back to a non-emailing demo mode.
# ---------------------------------------------------------------------------

# --- Email delivery (server-only, never exposed to the browser) -------------

# Resend API key. While this is empty the contact form runs in development
# mode: submissions are validated and printed to the server console, and the
# UI says explicitly that no email was sent.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=optifaipartnetship@gmail.com

# Sender address. Until a domain is verified in Resend you can only send from
# their sandbox address below. After verifying optifai.com (or whichever domain
# you register), change this to something like "OptifAI <hola@optifai.com>".
CONTACT_FROM_EMAIL=OptifAI <onboarding@resend.dev>

# --- Public values (inlined into the client bundle) -------------------------

# Optional on Vercel, recommended once a custom domain exists. Absolute site
# URL used for canonical URLs, hreflang, Open Graph, sitemap and robots.txt.
# Vercel falls back to VERCEL_PROJECT_PRODUCTION_URL when the project exposes
# system environment variables. A local production build must set this
# explicitly; local development uses localhost.
NEXT_PUBLIC_SITE_URL=https://example.com

# WhatsApp number in international format, digits only (Paraguay = 595).
# Local 0981507887 becomes 595981507887.
NEXT_PUBLIC_WHATSAPP_NUMBER=595981507887

# Scheduling link (Calendly, Cal.com, ...). Leave empty until one exists:
# every "book a call" CTA then scrolls to the contact form and pre-fills it.
NEXT_PUBLIC_BOOKING_URL=
