# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/blob-report/
/test-results/
/playwright/.cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.trace
*.tmp
*.temp

# tool caches
/.cache/
.eslintcache

# env files (can opt-in for committing if needed)
.env*
# ...but the template carries no secrets and must be committed.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
